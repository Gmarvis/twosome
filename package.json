{
  "name": "twosome",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @twosome/web dev",
    "build": "pnpm --filter @twosome/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @twosome/supabase migrate",
    "db:reset": "pnpm --filter @twosome/supabase reset",
    "db:types": "pnpm --filter @twosome/supabase types"
  }
}
