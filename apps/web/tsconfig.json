{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
      "@twosome/shared": ["../../packages/shared/src"],
      "@twosome/shared/*": ["../../packages/shared/src/*"],
      "@twosome/domain": ["../../packages/domain/src"],
      "@twosome/domain/*": ["../../packages/domain/src/*"],
      "@twosome/application": ["../../packages/application/src"],
      "@twosome/application/*": ["../../packages/application/src/*"],
      "@twosome/infrastructure": ["../../packages/infrastructure/src"],
      "@twosome/infrastructure/*": ["../../packages/infrastructure/src/*"]
    }
  },
  "include": ["src"]
}
